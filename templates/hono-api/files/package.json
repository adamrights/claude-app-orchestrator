{
  "name": "{{name}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "dependencies": {
    "hono": "^4.5.0",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.2.2",
    "zod": "^3.23.0",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.0",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.9.0",
    "@eslint/js": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
